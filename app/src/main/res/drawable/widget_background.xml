<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Solid Warm Cream Paper Card Background -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#FCF9F2" />
            <corners android:radius="14dp" />
        </shape>
    </item>

    <!-- Outer Sketched Border Pass (Espresso) -->
    <item
        android:left="2dp"
        android:top="2dp"
        android:right="2dp"
        android:bottom="2dp">
        <shape android:shape="rectangle">
            <stroke
                android:width="1.5dp"
                android:color="#4E342E" />
            <corners android:radius="13dp" />
        </shape>
    </item>

    <!-- Inner Sketched Border Pass (Slightly Offset and Thinner) -->
    <item
        android:left="5dp"
        android:top="5dp"
        android:right="5dp"
        android:bottom="5dp">
        <shape android:shape="rectangle">
            <stroke
                android:width="1dp"
                android:color="#8D6E63"
                android:dashWidth="6dp"
                android:dashGap="2dp" />
            <corners android:radius="11dp" />
        </shape>
    </item>
</layer-list>
